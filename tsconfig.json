{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src", "bin"],
  "exclude": ["tests", "node_modules", "dist"]
}
